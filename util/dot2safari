#!/bin/bash
# A Mac OS utility for viewing graphviz .dot files in Safari (as svg files)
# usage: cat test.dot | dot2safari

set -euo pipefail

if ! command -v dot >/dev/null 2>&1; then
    echo "Error: graphviz 'dot' not found" >&2
    exit 1
fi

SVGFILE=$(mktemp "${TMPDIR:-/tmp}/$(uuidgen).svg")

dot -Tsvg > "$SVGFILE"

open -a Safari "$SVGFILE"